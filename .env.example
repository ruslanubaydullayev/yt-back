# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
SITE_URL=https://api.ytshort.site
FRONTEND_URL=https://rank-v3.vercel.app
SECRET_KEY=change-me-to-a-random-64-char-string
CORS_ORIGINS=https://rank-v3.vercel.app,http://localhost:3000

# Google OAuth redirect URI (register in Google Cloud Console):
#   https://rank-v3.vercel.app/api/auth/callback/google

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nuxt_saas

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email (Resend) — optional
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Video processing
# -----------------------------------------------------------------------------
DATA_DIR=.data
MAX_RANKING_ITEMS=10
MAX_UPLOAD_MB=100
MAX_CLIP_DURATION_SECONDS=60
