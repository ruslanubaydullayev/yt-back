# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# App — SITE_URL is the public API origin (cookies, OAuth). FRONTEND_URL is the Nuxt app.
# IMPORTANT: SITE_URL must be exactly https://api.ytshort.site (no typos).
SITE_URL=https://api.ytshort.site
FRONTEND_URL=https://www.ytshort.site
SECRET_KEY=change-me-to-a-random-64-char-string
CORS_ORIGINS=https://www.ytshort.site,https://rank-v3.vercel.app,http://localhost:3000

# Google OAuth redirect URI (register in Google Cloud Console):
#   https://www.ytshort.site/api/auth/callback/google

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nuxt_saas

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email (Resend) — optional
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Video processing
# -----------------------------------------------------------------------------
DATA_DIR=.data
MAX_RANKING_ITEMS=10
MAX_UPLOAD_MB=100
MAX_CLIP_DURATION_SECONDS=60

# -----------------------------------------------------------------------------
# Nginx (production)
# -----------------------------------------------------------------------------
# If nginx sits in front of this API, set client_max_body_size to at least
# MAX_UPLOAD_MB. See nginx/api.conf — default nginx limit is 1m and causes 413
# on video uploads.
